# ── Environment Variables Template ─────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file.

# Groq API key. If blank, the backend runs in simulation mode.
GROQ_API_KEY=

# JWT secret for session signing (use a long random string in production)
JWT_SECRET=stadiummind-secret-jwt-key-2026-worldcup

# SQLite database path (relative to project root)
DATABASE_URL=sqlite:///./stadiummind.db

# Backend base URL
API_BASE_URL=http://localhost:8000

# Comma-separated frontend origins allowed to call the backend with cookies.
FRONTEND_ORIGINS=http://localhost:8443,http://127.0.0.1:8443

# For Railway + Cloudflare, set COOKIE_SECURE=true and COOKIE_SAMESITE=none.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
