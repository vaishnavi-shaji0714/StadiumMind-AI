# ── Environment Variables Template ─────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file.

# Groq API Key — get yours at https://console.groq.com
GROK_API_KEY=

# JWT secret for session signing (use a long random string in production)
JWT_SECRET=stadiummind-secret-jwt-key-2026-worldcup

# SQLite database path (relative to project root)
DATABASE_URL=sqlite:///./stadiummind.db

# Backend base URL
API_BASE_URL=http://localhost:8000
